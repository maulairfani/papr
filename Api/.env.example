# Copy to .env and adjust.

# LangGraph Agent Server URL.
#   local dev (uvicorn on host):  http://localhost:2024
#   docker-compose:               http://agent:2024  (set via compose `environment:`)
AGENT_URL=http://localhost:2024

# Dev auth secret — MUST be overridden in production.
PAPR_JWT_SECRET=dev-insecure-secret-change-me
